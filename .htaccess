Options -Indexes

# Custom error pages
ErrorDocument 404 /bismar/404.html
ErrorDocument 500 /bismar/500.html

# Charset default
AddDefaultCharset UTF-8

# --------------------------------------------------
# Pretty URLs untuk news detail
# --------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /bismar/

  # Skip file & folder yang memang ada
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # /bismar/judul-berita → newsdetail.html?slug=judul-berita
  RewriteRule ^([a-z0-9-]+)/?$ newsdetail.html?slug=$1 [L,QSA]
</IfModule>

# --------------------------------------------------
# Caching static assets
# --------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg              "access plus 1 month"
  ExpiresByType image/png               "access plus 1 month"
  ExpiresByType image/svg+xml           "access plus 1 month"
  ExpiresByType image/webp              "access plus 1 month"
  ExpiresByType image/x-icon            "access plus 1 year"
  ExpiresByType text/css                "access plus 1 week"
  ExpiresByType application/javascript  "access plus 1 week"
  ExpiresByType font/woff2              "access plus 1 year"
  ExpiresByType font/woff               "access plus 1 year"
</IfModule>

# --------------------------------------------------
# Gzip compression
# --------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# --------------------------------------------------
# Security headers
# --------------------------------------------------
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>